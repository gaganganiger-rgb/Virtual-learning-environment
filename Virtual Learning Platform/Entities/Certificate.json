{
  "name": "Certificate",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "User ID"
    },
    "course_id": {
      "type": "string",
      "description": "Course ID"
    },
    "certificate_id": {
      "type": "string",
      "description": "Unique certificate identifier"
    },
    "user_name": {
      "type": "string",
      "description": "User's name for the certificate"
    },
    "course_title": {
      "type": "string",
      "description": "Course title"
    },
    "completion_date": {
      "type": "string",
      "format": "date",
      "description": "Date of completion"
    },
    "score": {
      "type": "number",
      "description": "Final quiz score"
    },
    "certificate_url": {
      "type": "string",
      "description": "Generated certificate URL"
    }
  },
  "required": [
    "user_id",
    "course_id",
    "certificate_id",
    "user_name",
    "course_title"
  ],
  "rls": {
    "read": {
      "$or": [
        {
          "user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "write": {
      "user_id": "{{user.id}}"
    }
  }
}