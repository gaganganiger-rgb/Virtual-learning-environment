{
  "name": "ChatMessage",
  "type": "object",
  "properties": {
    "sender_id": {
      "type": "string",
      "description": "Message sender ID"
    },
    "receiver_id": {
      "type": "string",
      "description": "Message receiver ID"
    },
    "message": {
      "type": "string",
      "description": "Message content"
    },
    "is_ai_message": {
      "type": "boolean",
      "default": false,
      "description": "Whether this is an AI chatbot message"
    },
    "is_read": {
      "type": "boolean",
      "default": false,
      "description": "Whether the message has been read"
    }
  },
  "required": [
    "sender_id",
    "message"
  ],
  "rls": {
    "read": {
      "$or": [
        {
          "sender_id": "{{user.id}}"
        },
        {
          "receiver_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "write": {
      "$or": [
        {
          "sender_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}